<Window x:Class="HouseholdAccountBook.Views.Windows.ActionRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:properties="clr-namespace:HouseholdAccountBook.Properties"
        xmlns:vmw="clr-namespace:HouseholdAccountBook.ViewModels.Windows"
        xmlns:controls="clr-namespace:HouseholdAccountBook.Views.UserControls"
        mc:Ignorable="d"
        Height="Auto" Width="350" ShowInTaskbar="False" WindowStyle="ToolWindow">
    <Window.DataContext>
        <vmw:ActionRegistrationWindowViewModel x:Name="WVM"/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Gesture="Enter" Command="{Binding OKCommand}"/>
        <KeyBinding Gesture="Shift+Enter" Command="{Binding ContinueToOKCommand}"/>
        <KeyBinding Gesture="Esc" Command="{Binding CancelCommand}"/>
    </Window.InputBindings>
    
    <Window.Style>
        <Style TargetType="Window">
            <Style.Triggers>
                <DataTrigger Binding="{Binding RegKind}" Value="Add">
                    <Setter Property="Title" Value="{x:Static properties:Resources.Title_AddWindow}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RegKind}" Value="Edit">
                    <Setter Property="Title" Value="{x:Static properties:Resources.Title_EditWindow}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding RegKind}" Value="Copy">
                    <Setter Property="Title" Value="{x:Static properties:Resources.Title_AddWindow}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="0.5*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.25*" SharedSizeGroup="Header"/>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.25*" SharedSizeGroup="Button"/>
            </Grid.ColumnDefinitions>

            <!-- Id -->
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="5"  Visibility="{Binding App_IsDebug, Source={StaticResource Settings}, Converter={StaticResource BoolVisibilityConverter}}"
                       Text="Id" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Margin="5"  Visibility="{Binding App_IsDebug, Source={StaticResource Settings}, Converter={StaticResource BoolVisibilityConverter}}"
                       Text="{Binding ActionId, TargetNullValue='--'}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="5"  Visibility="{Binding App_IsDebug, Source={StaticResource Settings}, Converter={StaticResource BoolVisibilityConverter}}"
                       Text="GroupId" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Margin="5"  Visibility="{Binding App_IsDebug, Source={StaticResource Settings}, Converter={StaticResource BoolVisibilityConverter}}"
                       Text="{Binding GroupId, TargetNullValue='--'}" HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <!-- 帳簿 -->
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="5" 
                       Text="{x:Static properties:Resources.TextBlock_Book}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="5" Grid.ColumnSpan="2"
                      ItemsSource="{Binding BookSelectorVM.ItemList}" SelectedItem="{Binding BookSelectorVM.SelectedItem}" DisplayMemberPath="Name"/>

            <!-- 日付 -->
            <TextBlock Grid.Row="3" Grid.Column="0" Margin="5" 
                       Text="{x:Static properties:Resources.TextBlock_Date}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <controls:DateTimePicker Grid.Row="3" Grid.Column="1" Margin="5" 
                                     DateFormat="yyyy-MM-dd" SelectedDate="{Binding SelectedDate}"/>
            <Button Grid.Row="3" Grid.Column="3" Margin="5" Content="{x:Static properties:Resources.Button_Today}" Command="{Binding TodayCommand}"/>

            <!-- 収支 -->
            <TextBlock Grid.Row="4" Grid.Column="0" Margin="5" 
                       Text="{x:Static properties:Resources.TextBlock_IncomeOrExpenses}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="4" Grid.Column="1" Margin="5" Grid.ColumnSpan="2"
                      ItemsSource="{Binding BalanceKindSelectorVM.ItemList}" SelectedItem="{Binding BalanceKindSelectorVM.SelectedItem}" DisplayMemberPath="Value"/>

            <!-- 分類 -->
            <TextBlock Grid.Row="5" Grid.Column="0" Margin="5" 
                       Text="{x:Static properties:Resources.TextBlock_Category}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ListBox Grid.Row="5" Grid.Column="1" Margin="5" Grid.ColumnSpan="2"
                     ItemsSource="{Binding CategorySelectorVM.ItemList}" SelectedItem="{Binding CategorySelectorVM.SelectedItem}" DisplayMemberPath="Name"/>

            <!-- 項目 -->
            <TextBlock Grid.Row="6" Grid.Column="0" Margin="5" 
                       Text="{x:Static properties:Resources.TextBlock_Item}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ListBox Grid.Row="6" Grid.Column="1" Margin="5" Grid.ColumnSpan="2"
                     ItemsSource="{Binding ItemSelectorVM.ItemList}" SelectedItem="{Binding ItemSelectorVM.SelectedItem}" DisplayMemberPath="NameWithCategory"/>

            <!-- 金額 -->
            <TextBlock Grid.Row="7" Grid.Column="0" Margin="5" 
                       Text="{x:Static properties:Resources.TextBlock_AmountOfMoney}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <controls:NumericUpDown Grid.Row="7" Grid.Column="1" Margin="5" Value="{Binding InputedValue}" MinValue="1"/>
            <TextBlock Grid.Row="7" Grid.Column="2" Margin="5" HorizontalAlignment="Right"
                       Text="{Binding InputedValue, Converter={StaticResource IntToMoneyDisplayConverter}, TargetNullValue=0}"/>

            <!-- 店名 -->
            <TextBlock Grid.Row="8" Grid.Column="0" Margin="5"
                       Text="{x:Static properties:Resources.TextBlock_ShopName}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="8" Grid.Column="1" Margin="5" IsEditable="True" Grid.ColumnSpan="2"
                      ItemsSource="{Binding ShopSelectorVM.ItemList}" Text="{Binding ShopSelectorVM.SelectedItem, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name"/>

            <!-- 備考 -->
            <TextBlock Grid.Row="9" Grid.Column="0" Margin="5"
                       Text="{x:Static properties:Resources.TextBlock_Remark}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <ComboBox Grid.Row="9" Grid.Column="1" Margin="5" IsEditable="True" Grid.ColumnSpan="2"
                      ItemsSource="{Binding RemarkSelectorVM.ItemList}" Text="{Binding RemarkSelectorVM.SelectedItem, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Remark"/>

            <!-- チェック済 -->
            <TextBlock Grid.Row="10" Grid.Column="0" Margin="5" 
                       Text="{x:Static properties:Resources.TextBlock_Checked}" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RegKind}" Value="Edit">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <CheckBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" IsChecked="{Binding SelectedIfMatch}">
                <CheckBox.Style>
                    <Style TargetType="CheckBox">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RegKind}" Value="Edit">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </CheckBox.Style>
            </CheckBox>

            <!-- 繰り返し -->
            <GroupBox Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="3" 
                      Header="{x:Static properties:Resources.TextBlock_Repeat}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.25*" SharedSizeGroup="Header"/>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="0.25*" SharedSizeGroup="Button"/>
                    </Grid.ColumnDefinitions>

                    <!-- 回数 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center"
                               Text="{x:Static properties:Resources.TextBlock_Repeat_Count}"/>
                    <controls:NumericUpDown Grid.Row="0" Grid.Column="1" Margin="5" Value="{Binding InputedCount}" MinValue="1"/>
                    
                    <!-- 休日設定 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center"
                               Text="{x:Static properties:Resources.TextBlock_Repeat_Holiday}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="5" 
                              ItemsSource="{Binding HolidaySettingSelectorVM.ItemList}" SelectedItem="{Binding HolidaySettingSelectorVM.SelectedItem}" DisplayMemberPath="Value">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InputedCount}" Value="1">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                    
                    <!-- まとめて編集 -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center"
                               Text="{x:Static properties:Resources.TextBlock_Repeat_BulkEdit}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RegKind}" Value="Edit">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <CheckBox Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center" IsChecked="{Binding SelectedIfLink}">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RegKind}" Value="Edit">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding InputedCount}" Value="1">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>
                </Grid>
            </GroupBox>
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RegKind}" Value="Add">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding AddedByCsvComparison}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="0.3*"/>
                <ColumnDefinition Width="0.3*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{x:Static properties:Resources.Button_Continue}" Command="{Binding ContinueToOKCommand}"/>
            <Button Grid.Column="1" Content="{x:Static properties:Resources.Button_Registration}" Command="{Binding OKCommand}"/>
            <Button Grid.Column="2" Content="{x:Static properties:Resources.Button_Cancel}" Command="{Binding CancelCommand}"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding RegKind}" Value="Add">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding AddedByCsvComparison}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="{x:Static properties:Resources.Button_Registration}" Command="{Binding OKCommand}"/>
            <Button Grid.Column="1" Content="{x:Static properties:Resources.Button_Cancel}" Command="{Binding CancelCommand}"/>
        </Grid>
    </Grid>
</Window>
